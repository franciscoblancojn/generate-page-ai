{
  "$schema": "https://opencode.ai/config.json",
  "username": "developer",
  "instructions": ["AGENTS.md", "CONTEXT.md"],
  "agent": {
    "gpai-dev": {
      "description": "WordPress plugin developer especializado en Generate Page AI. Usa este agente cuando trabajes en funcionalidades del plugin GPAI.",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": {
          "git *": "allow",
          "npm *": "allow",
          "composer *": "allow",
          "*": "ask"
        }
      }
    },
    "gpai-reviewer": {
      "description": "Revisor de código que valida que los cambios cumplan las reglas del plugin GPAI y WordPress Coding Standards.",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": {
          "git diff *": "allow",
          "git log *": "allow",
          "git status": "allow",
          "*": "deny"
        }
      }
    }
  },
  "skills": {
    "paths": [".rules"]
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git *": "allow",
      "npm *": "allow",
      "composer *": "allow",
      "wp *": "ask",
      "*": "ask"
    }
  }
}
